# Node environment (development | staging | production)
NODE_ENV=

# AWS credentials (use dummy values for local development with LocalStack)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# LocalStack endpoint (local development only)
LOCALSTACK_ENDPOINT=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# DynamoDB table names (injected by CDK at deploy time; use defaults locally)
PRAYER_LOGS_TABLE=
FAST_LOGS_TABLE=
PRACTICING_PERIODS_TABLE=
USER_SETTINGS_TABLE=
USER_LIFECYCLE_JOBS_TABLE=
DELETED_USERS_TABLE=

# API
API_GATEWAY_URL=
DEPLOY_ENV=

# Frontend (Vite env vars must be prefixed with VITE_)
VITE_API_BASE_URL=
VITE_AUTH_MODE=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_AWS_REGION=
VITE_BASE_PATH=
VITE_APP_VERSION=
VITE_APP_EMAIL=
VITE_BROWSER_ERROR_ENDPOINT=
FRONTEND_BUCKET=
FRONTEND_DEPLOY_TARGET=
FRONTEND_API_MODE=
PAGES_ORIGIN=
PAGES_BASE_PATH=
PAGES_SITE_URL=
PAGES_CNAME=
