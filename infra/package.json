{
  "name": "infra",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "deploy:all": "cdk deploy --all --require-approval never",
    "deploy:data": "cdk deploy \"*data-stack*\" --require-approval never",
    "deploy:auth": "cdk deploy \"*auth-stack*\" --require-approval never",
    "deploy:api": "cdk deploy \"*api-stack*\" --require-approval never",
    "deploy:frontend": "cdk deploy \"*frontend-stack*\" --require-approval never",
    "deploy:alarms": "cdk deploy \"*alarm-stack*\" --require-approval never",
    "deploy:backup": "cdk deploy \"*backup-stack*\" --require-approval never",
    "destroy:all": "cdk destroy --all --force",
    "destroy:data": "cdk destroy \"*data-stack*\" --force",
    "destroy:auth": "cdk destroy \"*auth-stack*\" --force",
    "destroy:api": "cdk destroy \"*api-stack*\" --force",
    "destroy:frontend": "cdk destroy \"*frontend-stack*\" --force",
    "destroy:alarms": "cdk destroy \"*alarm-stack*\" --force",
    "destroy:backup": "cdk destroy \"*backup-stack*\" --force",
    "bootstrap": "cdk bootstrap"
  },
  "dependencies": {
    "aws-cdk-lib": "2.245.0",
    "constructs": "10.5.1",
    "esbuild": "0.25.12",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "aws-cdk": "2.1110.0",
    "typescript": "5.7.3"
  }
}