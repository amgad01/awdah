{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-language-manifest.mjs",
    "dev": "vite",
    "prebuild:prod": "node scripts/generate-language-manifest.mjs && node scripts/convert-og-image.mjs",
    "pretypecheck": "node scripts/generate-language-manifest.mjs",
    "build": "npm run prebuild:prod && tsc -b && vite build",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "prelint": "node scripts/generate-language-manifest.mjs",
    "typecheck": "tsc -b",
    "pretest": "node scripts/generate-language-manifest.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chromium": "npx playwright test --project=chromium"
  },
  "dependencies": {
    "@awdah/shared": "0.0.0",
    "@aws-sdk/client-cognito-identity-provider": "3.1005.0",
    "@tanstack/react-query": "5.90.21",
    "amazon-cognito-identity-js": "6.3.16",
    "clsx": "2.1.1",
    "framer-motion": "12.35.1",
    "i18next": "25.8.14",
    "jwt-decode": "4.0.0",
    "lucide-react": "0.577.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "16.5.6",
    "react-router-dom": "7.13.1",
    "recharts": "2.15.4",
    "swiper": "12.1.3",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "jsdom": "26.1.0",
    "prettier": "^3.8.1",
    "sharp": "0.34.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "7.3.2"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
