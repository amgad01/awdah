{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    "paths": {
      "@awdah/shared": ["../../packages/shared/src"],
      "@awdah/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../../packages/shared"
    }
  ]
}
