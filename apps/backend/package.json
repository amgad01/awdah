{
  "name": "@awdah/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "dev": "ts-node src/index.ts",
    "restore:s3": "ts-node -P tsconfig.scripts.json scripts/restore-from-s3.ts",
    "restore:sanitize": "ts-node -P tsconfig.scripts.json scripts/restore-sanitize.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run src/__tests__/api.test.ts",
    "build:layer": "cd layer/nodejs && npm ci --omit=dev && cd ../.."
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "3.1019.0",
    "@aws-sdk/client-dynamodb": "3.1005.0",
    "@aws-sdk/client-secrets-manager": "3.1005.0",
    "@aws-sdk/lib-dynamodb": "3.1005.0",
    "@umalqura/core": "0.0.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "http-status-codes": "2.3.0",
    "path-to-regexp": "8.4.0",
    "pino": "9.6.0",
    "ulid": "2.3.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@ampproject/remapping": "2.3.0",
    "istanbul-lib-source-maps": "5.0.6",
    "@types/aws-lambda": "8.10.147",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.2",
    "aws-sdk-client-mock": "4.1.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2"
  }
}
