{
  "name": "awdah",
  "private": true,
  "author": "Amgad Mahmoud",
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/shared",
    "infra"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/frontend",
    "dev:hybrid": "bash scripts/setup-hybrid-dev.sh dev",
    "dev:local": "echo \"VITE_AUTH_MODE=local\" > apps/frontend/.env.local",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "docker:up": "docker compose up -d localstack",
    "docker:down": "docker compose down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e --workspace=apps/frontend",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=apps/frontend",
    "check": "./scripts/pre-push-checks.sh",
    "check:quick": "./scripts/pre-push-quick.sh",
    "load:burst": "node scripts/load-burst-smoke.mjs",
    "restore:s3": "ts-node infra/scripts/restore-from-s3.ts",
    "restore:sanitize": "ts-node infra/scripts/restore-sanitize.ts",
    "deploy:dev": "cd infra && npx cdk deploy --all --context env=dev --require-approval never",
    "deploy:prod": "cd infra && npx cdk deploy --all --context env=prod --require-approval never",
    "build:frontend:dev": "bash scripts/build-frontend.sh dev",
    "build:frontend:prod": "bash scripts/build-frontend.sh prod",
    "deploy:all:dev": "bash scripts/deploy-all.sh dev",
    "deploy:all:prod": "bash scripts/deploy-all.sh prod",
    "outputs:dev": "./scripts/list-outputs.sh dev",
    "outputs:prod": "./scripts/list-outputs.sh prod",
    "deploy:frontend:dev": "bash scripts/deploy-frontend-cloud.sh dev",
    "deploy:frontend:prod": "bash scripts/deploy-frontend-cloud.sh prod",
    "deploy:frontend:cloud": "bash scripts/deploy-frontend-cloud.sh dev",
    "url:dev": "npm run get:dev:url --workspace=infra",
    "deploy": "./scripts/deploy.sh",
    "deploy:quick": "./scripts/deploy.sh --quick",
    "deploy:hotswap": "./scripts/deploy.sh --skip-bootstrap --skip-build --hotswap",
    "deploy:parallel": "./scripts/deploy.sh --skip-bootstrap --skip-build --parallel",
    "deploy:skip-setup": "./scripts/deploy.sh --skip-bootstrap --skip-build",
    "deploy:all": "./scripts/deploy-all.sh",
    "deploy:frontend": "./scripts/deploy-frontend.sh",
    "upload:frontend:dev": "bash scripts/upload-frontend.sh dev",
    "build-and-urepload-frontend": "bash scripts/upload-frontend.sh dev",
    "deploy:stack": "./scripts/deploy-stack.sh",
    "destroy": "./scripts/destroy.sh",
    "destroy:stack": "./scripts/destroy-stack.sh",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "flatted": "3.4.2",
    "graphemer": "1.4.0",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "magic-string": "0.30.21",
    "nanoid": "5.1.7",
    "pathe": "2.0.3",
    "prettier": "3.8.1",
    "strip-literal": "3.1.0",
    "tinyspy": "4.0.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.2"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "3.1005.0",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitest/coverage-v8": "4.1.2",
    "aws-sdk-client-mock": "4.1.0",
    "hijri-converter": "1.1.1",
    "html-parse-stringify": "3.0.1",
    "jq": "^1.7.2",
    "recharts": "2.14.1",
    "use-sync-external-store": "1.6.0"
  }
}
